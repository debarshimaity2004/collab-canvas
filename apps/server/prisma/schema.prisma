generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String       @id @default(uuid())
  email     String       @unique
  password  String
  name      String
  rooms     RoomMember[]
  createdAt DateTime     @default(now())
}

model Room {
  id        String       @id @default(uuid())
  name      String
  members   RoomMember[]
  snapshots Snapshot[]
  createdAt DateTime     @default(now())
}

model RoomMember {
  userId String
  roomId String
  role   String @default("editor")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([userId, roomId])
}

model Snapshot {
  id        String   @id @default(uuid())
  roomId    String
  data      Bytes
  version   Int
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
